# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ─── Database ─────────────────────────────────────────────────
# Connexion utilisée par l'application au runtime (via mysql2/promise)
# En local, ces valeurs sont identiques à .env pour le développement.
# En CI/déploiement, les vraies valeurs viennent des secrets.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=recettes_humaines
DB_USER=dev_app
DB_PASSWORD=ton_mot_de_passe_dev_app

# Compte admin BDD (migrations, seeds, DDL) — PAS utilisé par l'app
DB_ADMIN_USER=dev_admin
DB_ADMIN_PASSWORD=ton_mot_de_passe_dev_admin

# Base de test isolée — utilisée exclusivement par Jest + Supertest
DB_TEST_NAME=recettes_humaines_test

# ─── Comptes de test (seed) ──────────────────────────────────
# Ces comptes sont créés par database/scripts/04_seed_data.sql
# dans les DEUX bases (recettes_humaines ET recettes_humaines_test).
# Les mots de passe ci-dessous sont ceux de l'environnement de dev.
# En production/recette, les remplacer par des vrais comptes sécurisés.
#
# Rôle    | Pseudo        | Email                  | Mot de passe
# --------|---------------|------------------------|-------------
# admin   | admin_ovni    | admin@example.com      | Admin123!
# user    | mickael_b     | mickael@example.com    | User1234!
# user    | sofia_r       | sofia@example.com      | User1234!
# user    | jerome_k      | jerome@example.com     | User1234!
# user    | anonyme_test  | anon@example.com       | User1234!

# ─── JWT ─────────────────────────────────────────────────────
# En dev : n'importe quelle chaîne longue et aléatoire.
# En prod : générée via openssl rand -hex 64 et stockée dans les secrets.
JWT_SECRET=ta_cle_secrete_tres_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# ─── Logs ────────────────────────────────────────────────────
LOG_LEVEL=debug

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
