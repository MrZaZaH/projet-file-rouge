# ─── Server ───────────────────────────────────────────────────
# Environnement de test : Jest utilise ce fichier via tests/setup.js
# Le port 3001 évite les conflits avec le serveur de dev (port 3000)
NODE_ENV=test
PORT=3001

# ─── Database ─────────────────────────────────────────────────
# Connexion vers la base de test ISOLÉE (recettes_humaines_test).
# Même user que le développement (dev_app) mais base différente.
# Les tests TRUNCATEnt toutes les tables avant chaque test via
# clearDatabase() — donc on ne touche JAMAIS à la base de dev.
DB_HOST=localhost
DB_PORT=3306
DB_USER=dev_app
DB_PASSWORD=dev_app_polmnb2
DB_NAME=recettes_humaines_test
#            ↑ isolée de recettes_humaines (base de dev)

# ─── JWT ─────────────────────────────────────────────────────
# Clé différente du .env de dev volontairement ? Non, même clé ici
# car on ne teste PAS la sécurité JWT dans les tests fonctionnels.
# En CI, on pourrait utiliser une clé dédiée pour les tests.
JWT_SECRET=5852fc4bf484e2e79cdc227d0060d622e23db3612b793896ccdc262ad12bb3ec4a86bd5bd6e0913bf92b40e51c62451dc5105c17019ec829bac9dee38a85b991
JWT_EXPIRES_IN=1d
#            ↑ 1 jour au lieu de 7 en dev → durée plus courte en test

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001

# ─── Comptes de test (seed) ──────────────────────────────────
# Ces comptes existent dans recettes_humaines_test APRÈS le seed.
# Pendant les tests Jest, clearDatabase() les supprime et les tests
# créent leurs propres utilisateurs via POST /api/v1/auth/register.
# Les identifiants ci-dessous servent pour les tests MANUELS
# (ex: requêter l'API en mode test sur le port 3001).
#
# Rôle    | Pseudo        | Email                  | Mot de passe
# --------|---------------|------------------------|-------------
# admin   | admin_ovni    | admin@example.com      | Admin123!
# user    | mickael_b     | mickael@example.com    | User1234!
# user    | sofia_r       | sofia@example.com      | User1234!
# user    | jerome_k      | jerome@example.com     | User1234!
# user    | anonyme_test  | anon@example.com       | User1234!
