# ─── Server ───────────────────────────────────────────────────
# Environnement de test — copie ce fichier en .env.test
# et remplace les valeurs sensibles avant de lancer les tests.
NODE_ENV=test
PORT=3001

# ─── Database ─────────────────────────────────────────────────
# Connexion vers la base de test ISOLÉE (recettes_humaines_test).
# Les tests TRUNCATEnt toutes les tables — jamais de risque pour la dev.
DB_HOST=localhost
DB_PORT=3306
DB_USER=dev_app
DB_PASSWORD=ton_mot_de_passe_dev_app
DB_NAME=recettes_humaines_test
#            ↑ NE PAS mettre recettes_humaines ici (risque de perte de données)

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=ta_cle_secrete_de_test
JWT_EXPIRES_IN=1d

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001

